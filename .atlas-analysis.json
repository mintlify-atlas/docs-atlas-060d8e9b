  "keyFeatures": [
    "Multi-server management with encrypted credential storage",
    "Real-time monitoring of system status, array, and resources",
    "Docker container management (start, stop, restart)",
    "Virtual machine control with multiple actions",
    "Storage shares and disk array monitoring",
    "Notification management and archiving",
    "Progressive Web App with offline support",
    "Mobile-first responsive design",
    "CSRF protection and audit logging",
    "Self-signed certificate support for Unraid"
  ],
  "publicApiSurface": [
    "POST /api/servers/test",
