    "GET /api/docker",
    "GET /api/docker/:id/icon",
    "POST /api/docker/:id/:action",
    "GET /api/vms",
    "POST /api/vms/:id/:action",
    "GET /api/shares",
    "POST /api/notifications/:id/archive",
    "GET /api/settings/app",
    "PUT /api/settings/app"
